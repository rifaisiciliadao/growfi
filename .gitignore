docs/

# Dotenv files
.env
.env.local
.env.*.local
**/.env.local
**/.env.*.local

# Build caches
**/.vite/

# Local tools / editors
.claude/
.obsidian/
.DS_Store

# Local planning docs (not for upstream)
PLAN.md

# Graphics scratchpad (decks, social kit, design canvases — never upstream)
graphics/

# Platform subgraph build outputs
platform/subgraph/build/
platform/subgraph/generated/
platform/subgraph/node_modules/

# Platform frontend/backend node_modules (also covered by per-dir gitignores)
platform/*/node_modules/
