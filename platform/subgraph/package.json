{
  "name": "growfi-subgraph",
  "version": "5.0.0",
  "description": "GrowFi subgraph — indexes CampaignFactory + dynamic Campaign/StakingVault/HarvestManager templates",
  "private": true,
  "scripts": {
    "codegen": "graph codegen",
    "build": "graph build",
    "clean": "rm -rf build generated",
    "prepare": "npm run codegen && npm run build",
    "deploy:studio": "graph deploy --studio growfi",
    "deploy:local": "graph deploy --node http://localhost:8020 --ipfs http://localhost:5001 growfi",
    "create:local": "graph create --node http://localhost:8020 growfi"
  },
  "dependencies": {
    "@graphprotocol/graph-cli": "^0.90.0",
    "@graphprotocol/graph-ts": "^0.35.0"
  }
}
