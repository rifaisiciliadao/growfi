PORT=4001
HOST=0.0.0.0

# DigitalOcean Spaces (S3-compatible)
# Team:   turinglabs
# Project: Rifai
# Bucket: growfi-media @ fra1
#
# Create a key via doctl:
#   doctl spaces keys create <key-name> --grants 'bucket=growfi-media;permission=readwrite'
DO_SPACES_REGION=fra1
DO_SPACES_BUCKET=growfi-media
DO_SPACES_ENDPOINT=https://fra1.digitaloceanspaces.com
DO_SPACES_PUBLIC_BASE=https://growfi-media.fra1.digitaloceanspaces.com
DO_SPACES_KEY=
DO_SPACES_SECRET=

# --- Invite gating ---
# Invite records live as one JSON per ETH address on the same DO Space used for
# campaign images, under the prefix below. The frontend's "does this wallet have
# access?" check is a single GET on <prefix>/<lowercase-address>.json — no
# scanning, no DB.
INVITES_OBJECT_PREFIX=invites

# Public app URL embedded in approval emails (no trailing slash)
APP_URL=http://localhost:3000

# Inbox notified on every new invite request (best-effort fan-out, never
# blocks the user). Default: hey@growfi.dev — set to empty to disable.
ADMIN_NOTIFY_EMAIL=hey@growfi.dev

# Random shared secret used by the standalone admin dashboard. Send it via the
# X-Admin-Key header on every /api/admin/* call. If unset, all admin routes
# return 503.
ADMIN_API_KEY=

# Rate limit on /api/invite/request (per IP). Defaults: 5 requests / hour.
INVITE_RATE_WINDOW_MS=3600000
INVITE_RATE_MAX=5

# Resend transactional email. If RESEND_API_KEY is unset, emails are logged to
# stdout instead of being sent (useful for local dev).
RESEND_API_KEY=
RESEND_FROM=GrowFi <hello@growfi.app>
